# ====================================================
# AkatsukiSoap — переменные окружения (шаблон)
# Скопируйте этот файл:  cp .env.example .env
# Затем заполните реальными значениями.
# ====================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Домен или IP сервера (через запятую, если несколько)
DJANGO_ALLOWED_HOSTS=your-domain.ru,your-server-ip

# Базовый URL (для ссылок в письмах и т.п.)
BASE_URL=https://your-domain.ru

# --- Email (Mail.ru) ---
EMAIL_HOST_USER=akasoapinfo@mail.ru
EMAIL_HOST_PASSWORD=your-mail-app-password

# --- reCAPTCHA ---
RECAPTCHA_PUBLIC_KEY=6LcYhnMsAAAAANZc4b85HjsbEUZUKaUA4OW_KDBc
RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# --- hCaptcha ---
HCAPTCHA_SITEKEY=8516c4f4-6c80-49d0-aab2-46c2be8eb946
HCAPTCHA_SECRET=your-hcaptcha-secret
